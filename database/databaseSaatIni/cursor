DELIMITER $$
CREATE DEFINER=`root`@`localhost` PROCEDURE `sp_karyawan_belum_absen`(
    IN p_tanggal DATE
)
BEGIN
    DECLARE v_id_karyawan INT;
    DECLARE v_nip         VARCHAR(100);
    DECLARE v_done        BOOLEAN DEFAULT FALSE;
    DECLARE v_count       INT DEFAULT 0;

    -- Cursor: karyawan yang ada jadwal hari ini
    DECLARE cur_jadwal CURSOR FOR
        SELECT k.id_karyawan, k.NIP
        FROM   karyawan k
        JOIN   karyawan_jadwal kj ON kj.id_karyawan = k.id_karyawan
        JOIN   jadwal j           ON j.id_jadwal     = kj.id_jadwal
        WHERE  j.tanggal = p_tanggal
          AND  j.status  = 'Aktif';

    DECLARE CONTINUE HANDLER FOR NOT FOUND SET v_done = TRUE;

    -- Tabel sementara untuk hasil laporan
    DROP TEMPORARY TABLE IF EXISTS tmp_belum_absen;
    CREATE TEMPORARY TABLE tmp_belum_absen (
        id_karyawan INT,
        NIP         VARCHAR(100)
    );

    OPEN cur_jadwal;

    loop_jadwal: LOOP
        FETCH cur_jadwal INTO v_id_karyawan, v_nip;
        IF v_done THEN LEAVE loop_jadwal; END IF;

        -- Cek apakah sudah ada kehadiran hari ini
        SELECT COUNT(*) INTO v_count
        FROM   kehadiran kh
        JOIN   karyawan_jadwal kj2 ON kj2.id_jadwal = kh.id_jadwal
        WHERE  kj2.id_karyawan = v_id_karyawan
          AND  kh.tanggal      = p_tanggal;

        IF v_count = 0 THEN
            INSERT INTO tmp_belum_absen VALUES (v_id_karyawan, v_nip);
        END IF;

    END LOOP loop_jadwal;

    CLOSE cur_jadwal;

    -- Tampilkan hasil
    SELECT t.id_karyawan, t.NIP
    FROM   tmp_belum_absen t
    ORDER  BY t.NIP;

    DROP TEMPORARY TABLE IF EXISTS tmp_belum_absen;
END$$
DELIMITER ;
