-- ============================================================
-- DDL & DML - SISTEM MANAJEMEN KEHADIRAN KARYAWAN
-- ============================================================


-- ============================================================
-- DDL - DATA DEFINITION LANGUAGE
-- ============================================================

-- 1. TABEL USER
CREATE TABLE user (
    id_user         INT             PRIMARY KEY,
    username        VARCHAR(50)     NOT NULL UNIQUE,
    password_user   VARCHAR(255)    NOT NULL,
    nama_lengkap    VARCHAR(100)    NOT NULL,
    nomor_tlp_user  VARCHAR(20),
    status_akun     ENUM('aktif', 'nonaktif') NOT NULL DEFAULT 'aktif',
    user_created_at DATETIME        NOT NULL DEFAULT CURRENT_TIMESTAMP,
    role_user       ENUM('Karyawan', 'HR', 'Admin Vendor', 'Kepala Departemen', 'Super Admin') NOT NULL
);

-- 2. TABEL VENDOR
CREATE TABLE vendor (
    id_vendor       INT             PRIMARY KEY AUTO_INCREMENT,
    nama_vendor     VARCHAR(100)    NOT NULL,
    alamat_vendor   VARCHAR(255)
);

-- 3. TABEL ADMIN VENDOR
CREATE TABLE admin_vendor (
    id_admin_vendor INT             PRIMARY KEY AUTO_INCREMENT,
    id_user         INT             NOT NULL,
    id_vendor       INT             NOT NULL,
    CONSTRAINT fk_adminvendor_user   FOREIGN KEY (id_user)   REFERENCES user(id_user),
    CONSTRAINT fk_adminvendor_vendor FOREIGN KEY (id_vendor) REFERENCES vendor(id_vendor)
);

-- 4. TABEL KEPALA DEPARTEMEN
CREATE TABLE kepala_departemen (
    id_departemen   INT             PRIMARY KEY AUTO_INCREMENT,
    id_user         INT             NOT NULL,
    nama_departemen VARCHAR(100)    NOT NULL,
    CONSTRAINT fk_kapdep_user FOREIGN KEY (id_user) REFERENCES user(id_user)
);

-- 5. TABEL KARYAWAN
CREATE TABLE karyawan (
    id_karyawan             INT             PRIMARY KEY AUTO_INCREMENT,
    nip_karyawan            VARCHAR(20)     NOT NULL UNIQUE,
    alamat_karyawan         VARCHAR(255),
    tanggal_masuk_karyawan  DATE            NOT NULL,
    tanggal_keluar_karyawan DATE            NULL,
    id_user                 INT             NOT NULL,
    id_departemen           INT             NOT NULL,
    id_admin_vendor         INT             NOT NULL,
    CONSTRAINT fk_karyawan_user         FOREIGN KEY (id_user)         REFERENCES user(id_user),
    CONSTRAINT fk_karyawan_departemen   FOREIGN KEY (id_departemen)   REFERENCES kepala_departemen(id_departemen),
    CONSTRAINT fk_karyawan_adminvendor  FOREIGN KEY (id_admin_vendor) REFERENCES admin_vendor(id_admin_vendor)
);

-- 6. TABEL SHIFT
CREATE TABLE shift (
    id_shift            INT             PRIMARY KEY AUTO_INCREMENT,
    nama_tipe_shift     VARCHAR(50)     NOT NULL,
    jam_masuk_shift     TIME            NOT NULL,
    jam_keluar_shift    TIME            NOT NULL
);

-- 7. TABEL JADWAL
CREATE TABLE jadwal (
    id_jadwal       INT             PRIMARY KEY AUTO_INCREMENT,
    tanggal_jadwal  DATE            NOT NULL,
    status_jadwal   ENUM('aktif', 'nonaktif') NOT NULL DEFAULT 'aktif',
    id_shift        INT             NOT NULL,
    CONSTRAINT fk_jadwal_shift FOREIGN KEY (id_shift) REFERENCES shift(id_shift)
);

-- 8. TABEL TIPE KEHADIRAN
CREATE TABLE tipe_kehadiran (
    id_tipe_kehadiran   INT             PRIMARY KEY AUTO_INCREMENT,
    status_kehadiran    VARCHAR(50)     NOT NULL
);

-- 9. TABEL KEHADIRAN
CREATE TABLE kehadiran (
    id_kehadiran            INT             PRIMARY KEY AUTO_INCREMENT,
    id_jadwal               INT             NOT NULL,
    waktu_masuk_aktual      DATETIME        NULL,
    waktu_keluar_aktual     DATETIME        NULL,
    lokasi_masuk            VARCHAR(100)    NULL,
    lokasi_keluar           VARCHAR(100)    NULL,
    id_tipe_kehadiran       INT             NOT NULL,
    keterangan_kehadiran    TEXT            NULL,
    bukti                   VARCHAR(255)    NULL,
    CONSTRAINT fk_kehadiran_jadwal          FOREIGN KEY (id_jadwal)         REFERENCES jadwal(id_jadwal),
    CONSTRAINT fk_kehadiran_tipe            FOREIGN KEY (id_tipe_kehadiran) REFERENCES tipe_kehadiran(id_tipe_kehadiran)
);

-- 10. TABEL JADWAL KARYAWAN (Relasi Karyawan - Jadwal - Kehadiran)
CREATE TABLE jadwal_karyawan (
    id_relasi       INT             PRIMARY KEY AUTO_INCREMENT,
    id_karyawan     INT             NOT NULL,
    id_jadwal       INT             NOT NULL,
    id_kehadiran    INT             NULL,
    CONSTRAINT fk_jadkary_karyawan  FOREIGN KEY (id_karyawan)  REFERENCES karyawan(id_karyawan),
    CONSTRAINT fk_jadkary_jadwal    FOREIGN KEY (id_jadwal)    REFERENCES jadwal(id_jadwal),
    CONSTRAINT fk_jadkary_kehadiran FOREIGN KEY (id_kehadiran) REFERENCES kehadiran(id_kehadiran)
);

-- 11. TABEL LEMBUR
CREATE TABLE lembur (
    id_lembur           INT             PRIMARY KEY AUTO_INCREMENT,
    id_karyawan         INT             NOT NULL,
    status_lembur       ENUM('pending', 'selesai', 'dibatalkan') NOT NULL DEFAULT 'pending',
    mulai_lembur        DATETIME        NOT NULL,
    selesai_lembur      DATETIME        NULL,
    pekerjaan_lembur    TEXT            NULL,
    pevalidasi_lembur   VARCHAR(100)    NULL,
    CONSTRAINT fk_lembur_karyawan FOREIGN KEY (id_karyawan) REFERENCES karyawan(id_karyawan)
);

-- 12. TABEL REKAP KEHADIRAN
CREATE TABLE rekap_kehadiran (
    id_rekapan          INT             PRIMARY KEY AUTO_INCREMENT,
    id_karyawan         INT             NOT NULL,
    periode_bulan       INT             NOT NULL CHECK (periode_bulan BETWEEN 1 AND 12),
    tahun               INT             NOT NULL,
    total_jam_kerja     DECIMAL(8,2)    DEFAULT 0,
    total_lembur        DECIMAL(8,2)    DEFAULT 0,
    jumlah_hadir        INT             DEFAULT 0,
    jumlah_sakit        INT             DEFAULT 0,
    jumlah_izin         INT             DEFAULT 0,
    jumlah_mangkir      INT             DEFAULT 0,
    jumlah_cuti         INT             DEFAULT 0,
    jumlah_terlambat    INT             DEFAULT 0,
    status_validasi_rekap ENUM('valid', 'pending', 'ditolak') NOT NULL DEFAULT 'pending',
    CONSTRAINT fk_rekap_karyawan FOREIGN KEY (id_karyawan) REFERENCES karyawan(id_karyawan)
);

-- 13. TABEL REKAP HR
CREATE TABLE rekap_hr (
    id_rekapan_hr   INT             PRIMARY KEY AUTO_INCREMENT,
    id_admin_vendor INT             NOT NULL,
    id_hr_perekap   INT             NOT NULL,
    CONSTRAINT fk_rekaphr_adminvendor   FOREIGN KEY (id_admin_vendor) REFERENCES admin_vendor(id_admin_vendor),
    CONSTRAINT fk_rekaphr_hr            FOREIGN KEY (id_hr_perekap)   REFERENCES user(id_user)
);


