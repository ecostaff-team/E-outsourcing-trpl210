BEGIN
    DECLARE v_duplikat INT;

    SELECT COUNT(*) INTO v_duplikat
    FROM   kehadiran
    WHERE  id_jadwal = NEW.id_jadwal
      AND  tanggal   = NEW.tanggal;

    IF v_duplikat > 0 THEN
        SIGNAL SQLSTATE '45000'
            SET MESSAGE_TEXT =
                'Kehadiran untuk jadwal dan tanggal ini sudah dicatat sebelumnya.';
    END IF;
END
